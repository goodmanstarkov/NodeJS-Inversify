{
	"name": "nodejs-inversify",
	"version": "1.0.0",
	"description": "Node.js project with Inversify and Prisma",
	"license": "ISC",
	"author": "Alexander Starkov",
	"private": true,
	"type": "commonjs",
	"main": "src/main.ts",
	"scripts": {
		"dev": "npm run docker:postgres && npm run docker:redis && npm run migrate:generate && npm run migrate:deploy && nodemon",
		"build": "tsc",
		"dev:clean": "npm run clean && npm ci && npm run dev",
		"build:clean": "npm run clean && npm ci && npm run build",
		"migrate": "prisma migrate dev",
		"migrate:deploy": "prisma migrate deploy",
		"migrate:reset": "prisma migrate reset",
		"migrate:rollback": "prisma migrate rollback",
		"migrate:studio": "prisma studio",
		"migrate:generate": "prisma generate",
		"migrate:push": "prisma migrate push",
		"migrate:up": "prisma migrate up",
		"clean": "ts-node clean.ts",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"prettier": "prettier --write \"src/**/*.{ts,json}\"",
		"docker:up": "docker compose up -d --build",
		"docker:postgres": "docker compose up -d postgres",
		"docker:redis": "docker compose up -d redis"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.4.0",
		"@prisma/client": "^7.4.0",
		"@types/jsonwebtoken": "^9.0.10",
		"bcryptjs": "^3.0.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.2.4",
		"express": "^5.2.1",
		"inversify": "^7.11.0",
		"ioredis": "^5.9.3",
		"jsonwebtoken": "^9.0.3",
		"lodash": "^4.17.23",
		"pg": "^8.18.0",
		"reflect-metadata": "^0.2.2",
		"tslog": "^4.10.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/lodash": "^4.17.23",
		"@types/node": "^25.2.3",
		"@types/pg": "^8.16.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-n": "^17.23.2",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.3.0",
		"nodemon": "^3.1.11",
		"prettier": "^3.8.1",
		"prisma": "^7.4.0",
		"rimraf": "^6.1.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.55.0"
	}
}
